<?xml version="1.0" encoding="utf-8"?>
<data-extraction-rules>
    <cloud-backup>
        <include domain="sharedpref" path="."/>
        <exclude domain="sharedpref" path="gemini_api_key_prefs.xml"/>
        <exclude domain="sharedpref" path="telemetry_settings.xml"/>
        <exclude domain="sharedpref" path="roundtable_telemetry_prefs.xml"/>
        <exclude domain="sharedpref" path="roundtable_privacy_settings.xml"/>
    </cloud-backup>
    <device-transfer>
        <include domain="sharedpref" path="."/>
        <exclude domain="sharedpref" path="gemini_api_key_prefs.xml"/>
        <exclude domain="sharedpref" path="telemetry_settings.xml"/>
        <exclude domain="sharedpref" path="roundtable_telemetry_prefs.xml"/>
        <exclude domain="sharedpref" path="roundtable_privacy_settings.xml"/>
    </device-transfer>
</data-extraction-rules>
